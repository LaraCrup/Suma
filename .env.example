# Supabase Configuration
# Reemplaza estos valores con los de tu proyecto de Supabase
# Los puedes encontrar en: https://app.supabase.com/project/_/settings/api

SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-anon-key-aqui

# Push Notifications (VAPID)
# Generar con: npx web-push generate-vapid-keys
# La clave pública se expone al cliente. La privada solo va a Supabase Secrets.
VAPID_PUBLIC_KEY=tu-vapid-public-key-aqui
VAPID_PRIVATE_KEY=tu-vapid-private-key-aqui
VAPID_SUBJECT=mailto:tu-email-aqui
